<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- خلفية بيضاء -->
    <solid android:color="#FFFFFF"/>

    <!-- إطار رمادي -->
    <stroke android:width="1dp" android:color="#BDBDBD"/>

    <!-- زوايا مستديرة -->
    <corners android:radius="8dp"/>

    <!-- مسافة داخلية -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>
