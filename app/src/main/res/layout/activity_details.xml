<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:background="@color/colorPrimary"
        android:popupTheme="@style/MenuStyle"
        app:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/MenuStyle"
        app:title="@string/details_title"
        app:titleTextColor="@android:color/white" />



    <FrameLayout
        android:id="@+id/imageProfileDetails"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarDetails"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_background" />

        <TextView
            android:id="@+id/txtProfileLetter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="A"
            android:textColor="@android:color/white"
            android:textSize="40sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- الاسم -->

    <!-- رقم الجوال -->

    <!-- الأزرار مع النصوص جنب بعض -->

    <TextView
        android:id="@+id/txtDetailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:text="Contact Name"
        android:textColor="#555555"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.505"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageProfileDetails" />

    <TextView
        android:id="@+id/txtDetailMobile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="0568794568"
        android:textColor="#555555"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtDetailName" />

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtDetailMobile">

        <!-- زر الاتصال -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnCall"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/call"
                android:src="@drawable/ic_call"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtNormalCallNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Call"
                android:textColor="#555555"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- زر الرسالة -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnMessage"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/message"
                android:src="@drawable/ic_message"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtWhatsAppNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Message"
                android:textColor="#555555"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- زر الإيميل -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnEmail"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/email"
                android:src="@drawable/ic_email"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtVideoCallNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Email"
                android:textColor="#555555"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- زر الفيديو -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnVideo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/viedo"
                android:src="@drawable/ic_video"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtVideoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Video"
                android:textColor="#555555"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
